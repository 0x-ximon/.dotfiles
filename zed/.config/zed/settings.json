{
	"auto_update": false,
	"vim_mode": true,
	"cursor_shape": "bar",
	"vertical_scroll_margin": 5,
	"diff_view_style": "split",
	"restore_on_startup": "launchpad",
	"autosave": "on_focus_change",
	"show_edit_predictions": true,

	"ui_font_size": 16,
	"buffer_font_size": 16.0,
	"buffer_font_weight": 600,
	"relative_line_numbers": "enabled",
	"icon_theme": "Material Icon Theme",
	"buffer_font_family": "FiraCode Nerd Font",

	"minimap": { "show": "never" },
	"debugger": { "dock": "left" },
	"git_panel": { "dock": "left" },
	"project_panel": { "dock": "left" },
	"outline_panel": { "dock": "left" },
	"edit_predictions": { "mode": "eager" },
	"collaboration_panel": { "dock": "right" },
	"terminal": { "dock": "right", "font_size": 16.0 },

	"theme": {
		"mode": "system",
		"light": "GitHub Light",
		"dark": "GitHub Dark"
	},

	"vim": {
		"use_system_clipboard": "always"
	},

	"file_types": {
		"dotenv": [".env*"]
	},

	"languages": {
		"Rust": {
			"formatter": {
				"external": {
					"command": "rustfmt"
				}
			}
		},

		"Zig": {
			"formatter": {
				"language_server": {
					"name": "zls"
				}
			},
			"code_actions_on_format": {
				"source.organizeImports.zls": true,
				"source.fixAll.zls": true
			}
		},

		"Solidity": {
			"formatter": {
				"external": {
					"command": "forge",
					"arguments": ["fmt", "--raw", "-"]
				}
			}
		},

		"Kotlin": {
			"language_servers": ["kotlin-lsp"],
			"formatter": {
				"external": {
					"command": "ktfmt",
					"arguments": ["--kotlinlang-style", "-"]
				}
			}
		},

		"Swift": {
			"formatter": {
				"external": {
					"command": "swift-format",
					"arguments": ["-"]
				}
			}
		},

		"Lua": {
			"formatter": {
				"external": {
					"command": "stylua",
					"arguments": ["-"]
				}
			}
		},

		"TypeScript": {
			"enable_language_server": false
		},

		"Python": {
			"enable_language_server": false
		},

		"JSON": {
			"formatter": {
				"external": {
					"command": "biome"
				}
			}
		}
	},

	"language_servers": [
		"...",
		"!eslint",
		"!vtsls",
		"!tailwindcss-language-server",
		"!typescript-language-server"
	],

	"lsp": {}
}
