{
	// Core settings
	"git.autofetch": true,
	"keyboard.dispatch": "keyCode",
	"extensions.autoUpdate": false,
	"files.autoSave": "onFocusChange",
	"terminal.integrated.fontSize": 16,
	"extensions.ignoreRecommendations": true,
	"scm.repositories.selectionMode": "single",
	"git.openRepositoryInParentFolders": "always",
	"search.searchEditor.focusResultsOnSearch": true,

	"window.commandCenter": false,
	"window.restoreWindows": "none",
	"window.autoDetectColorScheme": true,
	"window.menuBarVisibility": "toggle",

	"workbench.startupEditor": "none",
	"workbench.navigationControl.enabled": false,
	"workbench.panel.showLabels": false,
	"workbench.activityBar.location": "top",
	"workbench.editor.empty.hint": "hidden",
	"workbench.browser.showInTitleBar": false,
	"workbench.iconTheme": "material-icon-theme",
	"workbench.preferredDarkColorTheme": "GitHub Dark Default",
	"workbench.preferredLightColorTheme": "GitHub Light Default",

	"editor.tabSize": 4,
	"editor.fontSize": 16,
	"editor.fontWeight": "bold",
	"editor.formatOnSave": true,
	"editor.fontLigatures": true,
	"editor.cursorStyle": "line",
	"editor.inlayHints.enabled": "off",
	"editor.stickyScroll.enabled": false,

	"editor.lineNumbers": "relative",
	"editor.minimap.enabled": false,
	"editor.inlineSuggest.enabled": true,
	"editor.guides.bracketPairs": "active",
	"editor.fontFamily": "'FiraCode Nerd Font'",
	"editor.codeActionsOnSave": {
		"source.fixAll.biome": "explicit",
		"source.organizeImports.biome": "explicit",

		"source.fixAll.ruff": "explicit",
		"source.organizeImports.ruff": "explicit"
	},

	"editor.tokenColorCustomizations": {
		"[*Light*]": {
			"textMateRules": [
				{
					"scope": "ref.matchtext",
					"settings": {
						"foreground": "#000"
					}
				}
			]
		},
		"[*Dark*]": {
			"textMateRules": [
				{
					"scope": "ref.matchtext",
					"settings": {
						"foreground": "#fff"
					}
				}
			]
		},
		"textMateRules": []
	},

	// Keymaps settings
	"vim.normalModeKeyBindings": [
		// General Keymaps
		{
			"before": ["U"],
			"after": ["<C-r>"]
		},
		{
			"before": ["H"],
			"after": ["^"]
		},
		{
			"before": ["L"],
			"after": ["$"]
		},
		{
			"before": ["J"],
			"after": ["}"]
		},
		{
			"before": ["K"],
			"after": ["{"]
		},

		// Layout Keymaps
		{
			"before": ["<leader>", "("],
			"commands": ["workbench.action.toggleSidebarVisibility"]
		},
		{
			"before": ["<leader>", ")"],
			"commands": ["workbench.action.toggleAuxiliaryBar"]
		},

		// Quick Keymaps
		{
			"before": ["<leader>", "w"],
			"commands": ["workbench.action.files.save"]
		},
		{
			"before": ["<leader>", "q"],
			"commands": ["workbench.action.closeActiveEditor"]
		},

		// QoL Keymaps
		{
			"before": ["<leader>", "<space>"],
			"commands": ["workbench.action.quickOpen"]
		},
		{
			"before": ["<leader>", "."],
			"commands": ["workbench.action.createTerminalEditor"]
		},
		{
			"before": ["<leader>", "~"],
			"commands": ["workbench.files.action.focusFilesExplorer"]
		},
		{
			"before": ["<leader>", "/"],
			"commands": ["workbench.action.quickTextSearch"]
		},
		{
			"before": ["<leader>", "%"],
			"commands": ["workbench.scm.focus"]
		},
		{
			"before": ["[", "<tab>"],
			"commands": ["workbench.action.previousEditorInGroup"]
		},
		{
			"before": ["]", "<tab>"],
			"commands": ["workbench.action.nextEditorInGroup"]
		},
		{
			"before": ["<leader>", "<tab>", "n"],
			"commands": ["workbench.action.files.newUntitledFile"]
		},

		// LSP Keymaps
		{
			"before": ["?"],
			"commands": ["editor.action.showHover"]
		},
		{
			"before": ["!"],
			"commands": ["editor.action.showHover"]
		},
		{
			"before": ["g", "d"],
			"commands": ["editor.action.revealDefinition"]
		},
		{
			"before": ["g", "e"],
			"commands": ["editor.action.revealDeclaration"]
		},
		{
			"before": ["g", "r"],
			"commands": ["editor.action.goToReferences"]
		},
		{
			"before": ["g", "i"],
			"commands": ["editor.action.goToImplementation"]
		},
		{
			"before": ["g", "t"],
			"commands": ["editor.action.goToTypeDefinition"]
		},
		{
			"before": ["<leader>", "l", "a"],
			"commands": ["editor.action.quickFix"]
		},
		{
			"before": ["<leader>", "l", "f"],
			"commands": ["editor.action.format"]
		},
		{
			"before": ["<leader>", "l", "r"],
			"commands": ["editor.action.rename"]
		},
		{
			"before": ["[", "d"],
			"commands": ["editor.action.marker.prev"]
		},
		{
			"before": ["]", "d"],
			"commands": ["editor.action.marker.next"]
		},

		// Plugin Keymaps
		{
			"before": ["-"],
			"commands": ["oil-code.open"]
		},
		{
			"before": ["<CR>"],
			"commands": ["oil-code.select"]
		}
	],

	// Extensions settings
	"vim.leader": "<space>",
	"oil-code.hasNerdFont": true,
	"vim.useSystemClipboard": true,
	"oil-code.disableVimKeymaps": true,
	"dotenv.enableAutocloaking": false,

	"haskell.manageHLS": "PATH",
	"biome.suggestInstallingGlobally": false,
	"ruff.lineLength": 120,

	"files.associations": {
		".env*": "dotenv"
	},

	// TODO: Remove when material icon theme adds official bruno folder icon
	"material-icon-theme.folders.customClones": [
		{
			"name": "tui-folder",
			"base": "ui",
			"color": "green-500",
			"lightColor": "light-green-700",
			"folderNames": [".tui", "tui"]
		},
		{
			"name": "bruno-collection",
			"base": "connection",
			"color": "orange-500",
			"lightColor": "light-orange-700",
			"folderNames": [".bruno", "bruno"]
		},
		{
			"name": "diagram-collection",
			"base": "images",
			"color": "blue-500",
			"lightColor": "light-blue-700",
			"folderNames": [".diagrams", ".drawings", "diagrams", "drawings"]
		}
	],
	"github.copilot.enable": {
		"*": true,
		"plaintext": false,
		"markdown": true,
		"scminput": false,
		"mdx": false
	},

	"better-comments.tags": [
		{
			"tag": "TODO",
			"color": "#2563EB",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		},
		{
			"tag": "BUG",
			"color": "#DC2626",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		},
		{
			"tag": "WARN",
			"color": "#FBBF24",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		},
		{
			"tag": "INFO",
			"color": "#10B981",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		},
		{
			"tag": "TEST",
			"color": "#7C3AED",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		},
		{
			"tag": "PERF",
			"color": "#FF00FF",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		},
		{
			"tag": "HELP",
			"color": "#00FFFF",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		}
	],

	// Language Specific Settings
	"[cpp]": {
		"editor.tabSize": 4
	},
	"[csharp]": {
		"editor.defaultFormatter": "csharpier.csharpier-vscode"
	},
	"[c]": {
		"editor.tabSize": 4
	},
	"[sql]": {},
	"[asm]": {},

	"[java]": {
		"editor.defaultFormatter": "redhat.java"
	},
	"[haskell]": {
		"editor.defaultFormatter": "haskell.haskell"
	},
	"[typescript]": {
		"editor.tabSize": 4,
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[python]": {
		"editor.tabSize": 4,
		"editor.defaultFormatter": "charliermarsh.ruff"
	},
	"[lisp]": {},

	"[javascript]": {
		"editor.tabSize": 2,
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescriptreact]": {
		"editor.tabSize": 2,
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascriptreact]": {
		"editor.tabSize": 2,
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[html]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},

	"[mdx]": {
		"editor.wordWrap": "on",
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[markdown]": {
		"editor.wordWrap": "on",
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},

	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[github-actions-workflow]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	}
}
